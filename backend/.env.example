# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT (make this a long random string)
JWT_SECRET=change_this_to_a_long_random_secret_key_123456789

# Admin Credentials (stored securely here, NOT in DB)
ADMIN_EMAIL=admin@dh.com
ADMIN_PASSWORD_HASH=$2a$10$yourhashedpasswordhere

# Server
PORT=5000
NODE_ENV=production

# Frontend URL (for CORS)
FRONTEND_URL=https://your-app.netlify.app
